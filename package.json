{
  "name": "vue-legal-docs-visualizer",
  "version": "0.2.2",
  "description": "A Vue component library for visualizing legal documents",
  "type": "module",
  "main": "./dist/vue-legal-docs-visualizer.umd.js",
  "module": "./dist/vue-legal-docs-visualizer.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-legal-docs-visualizer.es.js",
      "require": "./dist/vue-legal-docs-visualizer.umd.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc --project tsconfig.build.json",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@primeuix/themes": "^2.0.3",
    "cytoscape": "^3.33.4",
    "cytoscape-popper": "^4.0.1",
    "legal-docs-client": "^0.3.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@popperjs/core": "^2.11.8",
    "@primeuix/themes": "^2.0.3",
    "@types/cytoscape": "^3.31.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "vue": "^3.4.21",
    "vue-tsc": "^2.0.13"
  },
  "keywords": [
    "vue",
    "component",
    "legal",
    "documents",
    "visualizer"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaastrichtU-BISS/vue-legal-docs-visualizer.git"
  },
  "bugs": {
    "url": "https://github.com/MaastrichtU-BISS/vue-legal-docs-visualizer/issues"
  },
  "homepage": "https://github.com/MaastrichtU-BISS/vue-legal-docs-visualizer#readme",
  "author": "",
  "license": "MIT"
}
